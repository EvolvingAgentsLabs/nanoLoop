# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug on OpenRouter (any tool-calling model)
HARNESS_MODEL=openrouter/owl-alpha

# Optional: cheaper model for subagents
HARNESS_SUBAGENT_MODEL=openrouter/owl-alpha

# Cap reserved output tokens (OpenRouter bills 402 if balance < reserved)
HARNESS_MAX_TOKENS=4096

# Retry transient OpenRouter 429/5xx errors
HARNESS_MAX_RETRIES=5

# Optional: fall back to this model if primary keeps erroring
# HARNESS_FALLBACK_MODEL=anthropic/claude-sonnet-4.6

# Optional OpenRouter attribution headers
OPENROUTER_SITE_URL=https://localhost
OPENROUTER_APP_NAME=custom-hardness
